# PlayReady Sports — Environment Variables
# Copy this file to .env.local and fill in values before running.
# Never commit .env.local to version control.

# ─── Supabase (Frontend) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Paystack (Frontend) ────────────────────────────────────────────────────
VITE_PAYMENT_PROVIDER=paystack
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# ─── Analytics / Monitoring (optional, leave blank to disable) ──────────────
VITE_POSTHOG_KEY=phc_your-posthog-project-key
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── Supabase Edge Functions (set in Supabase Dashboard → Settings → Secrets)
# SUPABASE_URL                    (auto-injected by Supabase runtime)
# SUPABASE_ANON_KEY               (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY       Your service role key (keep secret)
# PAYSTACK_SECRET_KEY             Your Paystack secret key (sk_test_... or sk_live_...)
# PAYMENT_PROVIDER                paystack or moolre
# MOOLRE_ENV                      sandbox or live
# MOOLRE_BASE_URL                 https://sandbox.moolre.com or https://api.moolre.com
# MOOLRE_API_USER                 Your Moolre X-API-USER, e.g. playreadysports
# MOOLRE_ACCOUNT_NUMBER           Your Moolre account number
# MOOLRE_PUBLIC_KEY               Moolre public key (server-side secret for this app)
# MOOLRE_PRIVATE_KEY              Moolre private key (server-side secret)
# MOOLRE_ACCOUNT_SECRET           Moolre account secret, if needed for future webhook checks
# MOOLRE_VAS_KEY                  Moolre SMS/WhatsApp VAS key, needed later for SMS
# MOOLRE_SMS_SENDER_ID            Approved sender ID, e.g. PLAYREADY
# ALLOWED_ORIGIN                  Your production domain e.g. https://joinplayready.com
# APP_URL                         Frontend URL used for Moolre redirect fallback, e.g. https://joinplayready.com
# RESEND_API_KEY                  Your Resend API key (set as a Supabase secret; never expose in frontend env)
# RESEND_FROM_EMAIL               Optional sender, e.g. PlayReady <hello@joinplayready.com>
# OTP_HASH_SECRET                 Random server-only secret used to hash signup OTPs
